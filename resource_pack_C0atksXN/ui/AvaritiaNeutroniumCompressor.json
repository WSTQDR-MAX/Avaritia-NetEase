{
    "container_label": {
        "type": "label",
        "anchor_from": "top_middle",
        "anchor_to": "top_middle",
        "offset": [
            0,
            -3
        ],
        "layer": 2,
        "color": "$title_text_color",
        "text": "$container_title"
    },
    "namespace": "NeutroniumCompressor",
    "neutronium_compressor_grid_input": {
        "type": "grid",
        "collection_name": "netease_ui_container",
        "grid_dimensions": [
            1,
            1
        ],
        "grid_item_template": "NeutroniumCompressor.neutronium_compressor_input",
        "maximum_grid_items": 2
    },
    "neutronium_compressor_grid_output": {
        "type": "grid",
        "collection_name": "netease_container",
        "grid_dimensions": [
            1,
            1
        ],
        "grid_item_template": "NeutroniumCompressor.neutronium_compressor_output",
        "maximum_grid_items": 2
    },
    "neutronium_compressor_input@common.container_item": {
        "$cell_image_size|default": [
            18,
            18
        ],
        "$item_collection_name": "netease_ui_container",
        "size": [
            18,
            18
        ]
    },
    "neutronium_compressor_output@common.container_item": {
        "$cell_image_size|default": [
            26,
            26
        ],
        "$item_collection_name": "netease_container",
        "size": [
            26,
            26
        ]
    },
    "neutronium_compressor_panel": {
        "type": "panel",
        "controls": [
            {
                "container_gamepad_helpers@common.container_gamepad_helpers": {}
            },
            {
                "flying_item_renderer@common.flying_item_renderer": {
                    "layer": 11
                }
            },
            {
                "selected_item_details_factory@common.selected_item_details_factory": {
                    "control_name": "@NeutroniumCompressor.selected_item_details"
                }
            },
            {
                "item_lock_notification_factory@common.item_lock_notification_factory": {
                    "control_name": "@common.item_lock_notification"
                }
            },
            {
                "root_panel@common.root_panel": {
                    "controls": [
                        {
                            "common_panel@common.common_panel": {
                                "$dialog_background|default": "common.dialog_background_opaque",
                                "controls": [
                                    {
                                        "bg_image@$dialog_background": {
                                            "bindings": [
                                                {
                                                    "binding_name": "$close_button_visible_binding_name",
                                                    "binding_name_override": "#visible"
                                                }
                                            ],
                                            "controls": [
                                                {
                                                    "container_panel": {
                                                        "type": "panel",
                                                        "size": [
                                                            "100%",
                                                            "100.0%c+-7.0px"
                                                        ],
                                                        "layer": 5,
                                                        "controls": [
                                                            {
                                                                "neutronium_compressor_panel_top_half@NeutroniumCompressor.neutronium_compressor_panel_top_half": {
                                                                    "offset": [
                                                                        0,
                                                                        8
                                                                    ]
                                                                }
                                                            },
                                                            {
                                                                "inventory_panel_bottom_half_with_label@common.inventory_panel_bottom_half_with_label": {}
                                                            },
                                                            {
                                                                "hotbar_grid@common.hotbar_grid_template": {}
                                                            }
                                                        ]
                                                    }
                                                },
                                                {
                                                    "inventory_selected_icon_button@common.inventory_selected_icon_button": {}
                                                },
                                                {
                                                    "gamepad_cursor@common.gamepad_cursor_button": {}
                                                },
                                                {
                                                    "close@common.close_button": {
                                                        "ignored": "$use_compact_close_button",
                                                        "layer": "$close_button_layer",
                                                        "offset": "$close_button_offset"
                                                    }
                                                },
                                                {
                                                    "compact_close@common.compact_close_button": {
                                                        "ignored": "(not $use_compact_close_button)",
                                                        "layer": "$close_button_layer",
                                                        "offset": "$close_button_offset"
                                                    }
                                                }
                                            ],
                                            "layer": 1,
                                            "size": [
                                                "100%",
                                                "100.0%c+-37.0px"
                                            ]
                                        }
                                    }
                                ],
                                "size": [
                                    "100%",
                                    "100.0%c"
                                ]
                            }
                        }
                    ],
                    "layer": 1,
                    "size": [
                        176,
                        220
                    ]
                }
            }
        ]
    },
    "neutronium_compressor_panel_top_half": {
        "type": "panel",
        "anchor_from": "top_middle",
        "anchor_to": "top_middle",
        "size": [
            "100%+0px",
            "100%c+-40px"
        ],
        "controls": [
            {
                "neutronium_compressor_grid_input@NeutroniumCompressor.neutronium_compressor_grid_input": {
                    "offset": [
                        -42,
                        5
                    ]
                }
            },
            {
                "neutronium_compressor_grid_output@NeutroniumCompressor.neutronium_compressor_grid_output": {
                    "offset": [
                        40,
                        5
                    ]
                }
            },
            {
                "container_label@NeutroniumCompressor.container_label": {}
            },
            {
                "progress": {
                    "type": "label",
                    "offset": [
                        -2.0,
                        23.0
                    ],
                    "size": [
                        42.0,
                        10.0
                    ],
                    "color": [
                        0.9372549019607843,
                        0.9686274509803922,
                        1.0
                    ],
                    "font_scale_factor": 1.2,
                    "font_type": "default",
                    "text": "#progress",
                    "text_alignment": "center",
                    "property_bag": {
                        "#progress": "400/400"
                    },
                    "bindings": [
                        {
                            "binding_condition": "always_when_visible",
                            "binding_name": "#progress"
                        }
                    ]
                }
            },
            {
                "arrow": {
                    "type": "image",
                    "offset": [
                        -13.0,
                        5.0
                    ],
                    "size": [
                        28.0,
                        18
                    ],
                    "layer": 1,
                    "clip_direction": "left",
                    "clip_ratio": 0.0,
                    "keep_ratio": false,
                    "texture": "textures/ui/arrow"
                }
            },
            {
                "singularity": {
                    "type": "image",
                    "offset": [
                        12.0,
                        5.0
                    ],
                    "size": [
                        18.0,
                        18.0
                    ],
                    "layer": 1,
                    "clip_direction": "left",
                    "clip_ratio": 0.0,
                    "texture": "textures/ui/avaritia/neutronium_compressor/singularity_progress_0"
                }
            },
            {
                "item_render": {
                    "type": "panel",
                    "size": [
                        0.0,
                        0.0
                    ],
                    "controls": [
                        {
                            "item_output": {
                                "type": "custom",
                                "renderer": "inventory_item_renderer",
                                "offset": [
                                    67.0,
                                    5.0
                                ],
                                "size": [
                                    18.0,
                                    18.0
                                ],
                                "layer": 1,
                                "property_bag": {
                                    "#item_id_aux": 131072
                                }
                            }
                        },
                        {
                            "item_input": {
                                "type": "custom",
                                "renderer": "inventory_item_renderer",
                                "offset": [
                                    -65.0,
                                    5.0
                                ],
                                "size": [
                                    18.0,
                                    18.0
                                ],
                                "layer": 1,
                                "property_bag": {
                                    "#item_id_aux": 131072
                                }
                            }
                        }
                    ]
                }
            }
        ]
    },
    "neutronium_compressor_screen@common.inventory_screen_common": {
        "$close_on_player_hurt|default": true,
        "close_on_player_hurt": "$close_on_player_hurt",
        "variables": [
            {
                "$screen_background_alpha": 0.4,
                "$screen_bg_content": "common.screen_background",
                "$screen_content": "NeutroniumCompressor.neutronium_compressor_panel",
                "requires": "$desktop_screen"
            },
            {
                "$screen_content": "NeutroniumCompressor.neutronium_compressor_panel",
                "requires": "$pocket_screen"
            }
        ]
    },
    "selected_item_details@common.selected_item_details": {
        "offset": [
            0,
            0
        ]
    }
}