{
    "format_version": "1.10.0",
    "minecraft:attachable": {
        "description": {
            "animations": {
                "wield": "animation.bow.wield",
                "wield_first_person_pull": "animation.bow.wield_first_person_pull"
            },
            "geometry": {
                "bow_pulling_0": "geometry.bow_pulling_0",
                "bow_pulling_1": "geometry.bow_pulling_1",
                "bow_pulling_2": "geometry.bow_pulling_2",
                "default": "geometry.bow_standby"
            },
            "identifier": "avaritia:infinity_bow",
            "materials": {
                "default": "entity_alphatest",
                "enchanted": "entity_alphatest_glint"
            },
            "render_controllers": [
                "controller.render.bow"
            ],
            "scripts": {
                "animate": [
                    "wield",
                    {
                        "wield_first_person_pull": "query.main_hand_item_use_duration > 0.0f && c.is_first_person"
                    }
                ],
                "pre_animation": [
                    "variable.charge_amount = math.clamp((query.main_hand_item_max_duration - (query.main_hand_item_use_duration - query.frame_alpha + 1.0)) / 10.0, 0.0, 1.0f);"
                ]
            },
            "textures": {
                "bow_pulling_0": "textures/items/infinity_bow_pulling_0",
                "bow_pulling_1": "textures/items/infinity_bow_pulling_1",
                "bow_pulling_2": "textures/items/infinity_bow_pulling_2",
                "default": "textures/items/infinity_bow_standby",
                "enchanted": "textures/misc/enchanted_item_glint"
            }
        }
    }
}